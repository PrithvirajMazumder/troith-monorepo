model Bank {
  id            String    @id @default(cuid())
  accountNumber BigInt
  name          String
  ifsc          String
  branch        String
  userId        String
  holderName    String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Invoice Invoice[]
}
